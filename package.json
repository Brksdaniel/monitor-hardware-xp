{
  "name": "monitor-hardware-xp",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "node-fetch": "^3.3.2",
    "systeminformation": "^5.31.1"
  },
  "build": {
    "appId": "com.seupc.monitor",
    "productName": "Monitor de Hardware XP",
    "extraResources": [
      {
        "from": "lhm",
        "to": "lhm"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  }
}
