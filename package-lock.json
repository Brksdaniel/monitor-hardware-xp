{
  "name": "monitor-hardware-xp",
  "version": "1.0.0",
  "description": "Monitor de Hardware estilo Windows XP",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.seupc.monitor",
    "productName": "Monitor de Hardware XP",
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}